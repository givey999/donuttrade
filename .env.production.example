# DonutTrade Production Environment (.env on the Droplet)
# Copy this to .env on the server and fill in all values.

NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Database — these must match POSTGRES_USER and POSTGRES_PASSWORD below
DATABASE_URL=postgresql://donuttrade:strong_password_here@postgres:5432/donuttrade
REDIS_URL=redis://redis:6379

# Postgres container credentials (used by docker-compose.production.yml)
POSTGRES_USER=donuttrade
POSTGRES_PASSWORD=strong_password_here

# Domain
CORS_ORIGIN=https://donuttrade.com
API_URL=https://donuttrade.com

# Microsoft OAuth (https://portal.azure.com → App registrations)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://donuttrade.com/auth/microsoft/callback

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://donuttrade.com/auth/discord/callback

# Email (optional)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@donuttrade.com

# JWT secrets (min 32 chars each — generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Bot webhook secret (min 32 chars — generate with: openssl rand -hex 32)
BOT_WEBHOOK_SECRET=

# Minecraft server
MC_SERVER_HOST=donutsmp.net
MC_SERVER_PORT=25565
MC_SERVER_VERSION=1.21.11
MC_BOT_USERNAME=
MC_BOT_DISPLAY_NAME=DonutTrade

# Marketplace
MARKETPLACE_COMMISSION_RATE=0.02

# Management Bot (Discord ticket system)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_DEPOSIT_CATEGORY_ID=
DISCORD_WITHDRAWAL_CATEGORY_ID=
DISCORD_MODERATOR_ROLE_ID=
DISCORD_PANEL_CHANNEL_ID=
DISCORD_LOGS_CHANNEL_ID=
DISCORD_BOOST_CHANNEL_ID=
DISCORD_BOOST_BENEFITS_CHANNEL_ID=

# Code signing (min 32 chars — generate with: openssl rand -hex 32)
CODE_SIGNING_SECRET=

# Web - Discord invite URL for "Open Discord" button in deposit/withdraw modals
NEXT_PUBLIC_DISCORD_INVITE_URL=
