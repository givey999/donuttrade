# Caddyfile - HTTPS reverse proxy with automatic Let's Encrypt certificates

{
    https_port 9443
    http_port 80
    auto_https disable_redirects
}

http://moldo.go.ro:80, http://:80 {
    redir https://{host}:9443{uri} permanent
}

moldo.go.ro:9443 {
    # API auth routes (specific paths, not /auth/callback which is a frontend page)
    handle /auth/microsoft* {
        reverse_proxy api:3001
    }
    handle /auth/discord* {
        reverse_proxy api:3001
    }
    handle /auth/me {
        reverse_proxy api:3001
    }
    handle /auth/refresh {
        reverse_proxy api:3001
    }
    handle /auth/logout* {
        reverse_proxy api:3001
    }
    handle /auth/set-username {
        reverse_proxy api:3001
    }
    handle /auth/verification/* {
        reverse_proxy api:3001
    }

    # Note: /internal/* routes are NOT exposed through Caddy.
    # The bot-bridge calls http://api:3001 directly on the Docker network.

    # JSON API requests (from apiFetch / XHR) → API backend
    # This catches all programmatic API calls, including /admin/*, /transactions,
    # /marketplace, /orders, /inventory, etc. Browser page navigations don't
    # send Content-Type headers, so they fall through to the frontend below.
    @api_request header Content-Type "application/json*"
    handle @api_request {
        reverse_proxy api:3001
    }

    # Future: explicit /api/* prefix
    handle /api/* {
        reverse_proxy api:3001
    }

    # Frontend
    handle {
        reverse_proxy web:3000
    }

    encode gzip

    log {
        output stdout
        format console
    }
}
