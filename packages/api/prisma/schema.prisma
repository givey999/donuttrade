generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id                          String    @id @default(uuid())

  // Authentication provider used for signup
  authProvider                String    @map("auth_provider") // 'microsoft', 'discord', 'email'

  // Minecraft identity (manually entered by user)
  minecraftUsername            String?   @unique @map("minecraft_username")

  // Microsoft OAuth identity (optional - only for Microsoft auth users)
  microsoftId                 String?   @unique @map("microsoft_id")

  // Discord OAuth identity (optional - only for Discord auth users)
  discordId                   String?   @unique @map("discord_id")
  discordUsername              String?   @map("discord_username")

  // Email/Password identity (optional - only for email auth users)
  email                       String?   @unique
  passwordHash                String?   @map("password_hash")
  emailVerified               Boolean   @default(false) @map("email_verified")
  emailVerificationCode       String?   @map("email_verification_code")
  emailVerificationExpiresAt  DateTime? @map("email_verification_expires_at")

  // Payment verification
  verificationAmount          Int?      @map("verification_amount")       // Random 1-1000
  verificationExpiresAt       DateTime? @map("verification_expires_at")   // 15-minute deadline
  verificationStatus          String    @default("pending") @map("verification_status") // 'pending', 'verified', 'expired'

  // Account state
  balance                     Decimal   @default(0) @db.Decimal(20, 2)
  role                        String    @default("user")          // 'user' | 'moderator' | 'manager' | 'admin' | 'leader'
  timedOutUntil               DateTime? @map("timed_out_until")
  timeoutReason               String?   @map("timeout_reason")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  lastLoginAt                 DateTime? @map("last_login_at")
  bannedAt                    DateTime? @map("banned_at")
  banReason                   String?   @map("ban_reason")
  tradingVolume               Decimal   @default(0) @map("trading_volume") @db.Decimal(20, 2)

  // Relations
  sessions                    Session[]
  transactions                Transaction[]
  withdrawals                 Withdrawal[]
  inventoryItems              InventoryItem[]
  itemDeposits                ItemDeposit[]
  itemWithdrawals             ItemWithdrawal[]
  orders                      Order[]
  orderFills                  OrderFill[] @relation("orderFills")
  auditLogs                   AuditLog[]
  cosmetics                   UserCosmetics?
  platformSettingsUpdated     PlatformSettings[] @relation("platformSettingsUpdated")

  @@index([discordId])
  @@index([email])
  @@index([verificationStatus])
  @@index([role])
  @@map("users")
}

model Session {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String   @unique @map("refresh_token_hash")
  userAgent        String?  @map("user_agent")
  ipAddress        String?  @map("ip_address")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  lastUsedAt       DateTime @default(now()) @map("last_used_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthState {
  state       String   @id
  authMethod  String   @map("auth_method") // 'microsoft', 'discord'
  redirectUrl String?  @map("redirect_url")
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("auth_states")
}

// ============================================================================
// FINANCIAL — Transactions & Withdrawals (Phase 7)
// ============================================================================

model Transaction {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // 'deposit' | 'withdrawal' | 'purchase' | 'sale'
  amount        Decimal  @db.Decimal(20, 2)
  balanceBefore Decimal  @map("balance_before") @db.Decimal(20, 2)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(20, 2)
  description   String?
  metadata      Json?    @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model Withdrawal {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal   @db.Decimal(20, 2)
  status        String    @default("pending") // 'pending' | 'approved' | 'processing' | 'completed' | 'denied' | 'failed'
  transactionId String?   @unique @map("transaction_id")
  failReason    String?   @map("fail_reason")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  @@index([userId])
  @@index([status])
  @@map("withdrawals")
}

// ============================================================================
// HEALTH CHECK (from Phase 0)
// ============================================================================

model HealthCheck {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  status    String

  @@map("health_checks")
}

// ============================================================================
// ITEM CATALOG & INVENTORY
// ============================================================================

model CatalogItem {
  id          String   @id @default(uuid())
  name        String   @unique                    // "zombie_spawner"
  displayName String   @map("display_name")       // "Zombie Spawner"
  category    String   @default("spawner")
  description String?
  iconUrl     String?  @map("icon_url")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  inventoryItems  InventoryItem[]
  itemDeposits    ItemDeposit[]
  itemWithdrawals ItemWithdrawal[]
  orders          Order[]

  @@index([category])
  @@index([enabled])
  @@map("catalog_items")
}

model InventoryItem {
  id               String      @id @default(uuid())
  userId           String      @map("user_id")
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogItemId    String      @map("catalog_item_id")
  catalogItem      CatalogItem @relation(fields: [catalogItemId], references: [id])
  quantity         Int         @default(0)
  reservedQuantity Int         @default(0) @map("reserved_quantity")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@unique([userId, catalogItemId])
  @@index([userId])
  @@map("inventory_items")
}

// ============================================================================
// ITEM DEPOSITS & WITHDRAWALS
// ============================================================================

model ItemDeposit {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogItemId String    @map("catalog_item_id")
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id])
  quantity      Int
  status        String    @default("pending")  // pending | verified | confirmed | rejected
  adminId       String?   @map("admin_id")
  adminNotes    String?   @map("admin_notes")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")
  code             String?   @unique
  codeExpiresAt    DateTime? @map("code_expires_at")
  codeVerifiedAt   DateTime? @map("code_verified_at")
  ticketChannelId  String?   @map("ticket_channel_id")
  ticketLabel      String?   @map("ticket_label")
  closedBy         String?   @map("closed_by")
  closeReason      String?   @map("close_reason")

  @@index([userId])
  @@index([status])
  @@map("item_deposits")
}

model ItemWithdrawal {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogItemId String    @map("catalog_item_id")
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id])
  quantity      Int
  status        String    @default("pending")  // pending | verified | processing | completed | failed | cancelled
  adminId       String?   @map("admin_id")
  failReason    String?   @map("fail_reason")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")
  code             String?   @unique
  codeExpiresAt    DateTime? @map("code_expires_at")
  codeVerifiedAt   DateTime? @map("code_verified_at")
  ticketChannelId  String?   @map("ticket_channel_id")
  ticketLabel      String?   @map("ticket_label")
  closedBy         String?   @map("closed_by")
  closeReason      String?   @map("close_reason")

  @@index([userId])
  @@index([status])
  @@map("item_withdrawals")
}

// ============================================================================
// AUDIT LOG
// ============================================================================

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String   @map("actor_id")          // Admin who performed the action
  actor       User     @relation(fields: [actorId], references: [id])
  action      String                              // e.g. 'user.ban', 'deposit.confirm'
  targetType  String   @map("target_type")        // 'user', 'deposit', 'withdrawal', 'order', 'catalog'
  targetId    String?  @map("target_id")          // ID of the affected entity
  details     Json?    @db.JsonB                  // Action-specific metadata
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// PLATFORM SETTINGS
// ============================================================================

model PlatformSettings {
  key        String    @id
  value      String
  updatedAt  DateTime  @updatedAt @map("updated_at")
  updatedBy  String?   @map("updated_by")
  updatedByUser User?  @relation("platformSettingsUpdated", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("platform_settings")
}

// ============================================================================
// USER COSMETICS
// ============================================================================

model UserCosmetics {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlockedColors      String[] @default([]) @map("unlocked_colors")
  unlockedFonts       String[] @default([]) @map("unlocked_fonts")
  hiddenModePurchased Boolean  @default(false) @map("hidden_mode_purchased")
  hiddenMode          Boolean  @default(false) @map("hidden_mode")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("user_cosmetics")
}

// ============================================================================
// MARKETPLACE ORDERS
// ============================================================================

model Order {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String    // 'buy' | 'sell'
  catalogItemId   String    @map("catalog_item_id")
  catalogItem     CatalogItem @relation(fields: [catalogItemId], references: [id])
  quantity        Int
  filledQuantity  Int       @default(0) @map("filled_quantity")
  pricePerUnit    Decimal   @map("price_per_unit") @db.Decimal(20, 2)
  commissionRate  Decimal   @map("commission_rate") @db.Decimal(5, 4)  // e.g. 0.0200
  escrowAmount    Decimal   @map("escrow_amount") @db.Decimal(20, 2)
  premiumFee      Decimal   @default(0) @map("premium_fee") @db.Decimal(20, 2)
  isPremium       Boolean   @default(false) @map("is_premium")
  status          String    @default("active")  // active | completed | cancelled | expired
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  completedAt     DateTime? @map("completed_at")
  borderColor    String?  @map("border_color")
  usernameColor  String?  @map("username_color")
  usernameFont   String?  @map("username_font")

  fills           OrderFill[]

  @@index([status, expiresAt])
  @@index([userId])
  @@index([catalogItemId])
  @@index([type, status])
  @@map("orders")
}

model OrderFill {
  id               String   @id @default(uuid())
  orderId          String   @map("order_id")
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  filledByUserId   String   @map("filled_by_user_id")
  filledByUser     User     @relation("orderFills", fields: [filledByUserId], references: [id])
  quantity         Int
  pricePerUnit     Decimal  @map("price_per_unit") @db.Decimal(20, 2)
  totalPrice       Decimal  @map("total_price") @db.Decimal(20, 2)
  commissionAmount Decimal  @map("commission_amount") @db.Decimal(20, 2)
  netAmount        Decimal  @map("net_amount") @db.Decimal(20, 2)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([filledByUserId])
  @@map("order_fills")
}
