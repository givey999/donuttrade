{
  "name": "@donuttrade/api",
  "version": "1.0.0",
  "description": "DonutTrade API server",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@donuttrade/shared": "workspace:*",
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/rate-limit": "9",
    "@fastify/sensible": "^5.5.0",
    "@prisma/client": "^5.9.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.0",
    "prisma": "^5.9.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
