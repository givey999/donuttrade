# DonutTrade Platform - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://dev:dev@localhost:5432/donuttrade

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# Microsoft OAuth (Required for Phase 2+)
# =============================================================================
# Azure AD Application credentials
# Get these from Azure Portal -> Microsoft Entra ID -> App registrations
#
# Production App Registration (moldo.go.ro):
#   Application (client) ID: 214728de-2c44-4234-b82b-37d6ef43ef21
#   Object ID: 9b49dd50-e476-4e8f-a841-4aa797b015ff
#   Directory (tenant) ID: 24e7d5bd-d8b2-4d5c-85d6-8a28c6ca889b
#
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Development: http://localhost:3000/auth/callback
# Production: https://moldo.go.ro:9443/auth/microsoft/callback
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback

# =============================================================================
# Discord OAuth (Required for Phase 3+)
# =============================================================================
# Get these from Discord Developer Portal -> Applications -> OAuth2
# See docs/admin-auth-setup-guide.md for full setup instructions
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Development: http://localhost:3000/auth/discord/callback
# Production: https://moldo.go.ro:9443/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# =============================================================================
# Email Service - Resend (Required for Phase 3+)
# =============================================================================
# Get an API key from https://resend.com
# The from address must be from a verified domain in Resend
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@donuttrade.com

# =============================================================================
# JWT Secrets (Required for Phase 4+)
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
